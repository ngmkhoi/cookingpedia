# Required for API startup
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cookpedia"
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Required JWT secrets and TTLs. These are template values only.
JWT_ACCESS_SECRET="replace-me-access"
JWT_REFRESH_SECRET="replace-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Local dev can stay empty. For subdomains in production, use e.g. .ngmkhoidesign.tech
COOKIE_DOMAIN=""

# Required backend Firebase admin config from the service account JSON
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=""


SEED_ADMIN_EMAIL="admin@cookpedia.local"
SEED_ADMIN_PASSWORD="AdminPass123!"
SEED_ADMIN_USERNAME="cookpedia-admin"
SEED_ADMIN_DISPLAY_NAME="Cookpedia Admin"

# Optional: force seed profile. Defaults to `production` when NODE_ENV=production, otherwise `local`.
SEED_DATA_PROFILE="local"
